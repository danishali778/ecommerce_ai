# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Backend
APP_ENV=development
APP_PORT=8000
APP_NAME=CommerceOps AI API
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
PUBLIC_APP_URL=http://localhost:8000
SECRET_STORE_ROOT=
LOW_INVENTORY_THRESHOLD=5

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Supabase - required even for local Docker Compose. This repo does not self-host Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_REDIRECT_URL=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,read_orders,read_customers,read_locations
SHOPIFY_API_VERSION=2026-04

# LLM
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
